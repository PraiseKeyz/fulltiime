# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=fulltiime
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_DB=fulltiime_db

# ── Docker ────────────────────────────────────────────────────────────────────
DOCKERHUB_USERNAME=your-dockerhub-username

# ── Backend ───────────────────────────────────────────────────────────────────
JWT_SECRET=your-strong-jwt-secret-here
JWT_REFRESH_SECRET=your-strong-refresh-secret-here
FRONTEND_URL=https://beta.fulltiime.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
SPORTMONKS_API_KEY=your-sportmonks-api-key-here

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.fulltiime.com
NEXT_PUBLIC_FRONTEND_URL=https://beta.fulltiime.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_SITE_URL=https://fulltiime.com
NEXT_PUBLIC_COMING_SOON_ENABLED=false
