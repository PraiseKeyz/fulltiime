PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://fulltiime:fulltiime_password@localhost:5432/fulltiime_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-this-in-production

# Frontend
FRONTEND_URL=http://localhost:3000

# SportMonks
SPORTMONKS_API_KEY=your-sportmonks-api-key-here

# Google sign-in (Google Identity Services) — OAuth 2.0 client ID, no secret needed
GOOGLE_CLIENT_ID=

# LLM — pick which provider LlmService talks to (default: anthropic).
# All three implement the same interface, so this is the only line you change to switch.
# Choices: anthropic | openai | gemini
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-..
OPENAI_API_KEY=sk-..
GEMINI_API_KEY=..

# ZeptoMail (transactional emails — verification, password reset, welcome)
ZEPTOMAIL_API_KEY=Zoho-enczapikey ..
ZEPTOMAIL_FROM_EMAIL=no-reply@fulltiime.com
ZEPTOMAIL_FROM_NAME=Fulltiime
# Cloudinary (studio media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
