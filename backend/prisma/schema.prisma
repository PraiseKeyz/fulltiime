generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FINISHED
  POSTPONED
  CANCELLED
}

enum PlayerPosition {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

enum MatchTextKind {
  PREVIEW
  OVERVIEW
  ABOUT
  REPORT
  INFO
}

enum ArticleCategory {
  NEWS
  ANALYSIS
  INTERVIEW
  TRANSFER
  MATCH_REPORT
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  username        String    @unique
  password_hash   String?
  google_id       String?   @unique
  full_name       String?
  avatar_url      String?
  role            Role      @default(USER)
  is_verified     Boolean   @default(false)
  refresh_token   String?

  // Email verification & password reset — store a sha256 hash of the token
  // (the raw token only ever lives in the emailed link), plus an expiry.
  verification_token    String?   @unique
  verification_expires  DateTime?
  reset_token           String?   @unique
  reset_expires         DateTime?

  favorite_teams  Team[]    @relation("UserFavoriteTeams")
  favorite_leagues League[] @relation("UserFavoriteLeagues")
  articles        Article[]
  chat_messages   LiveChatMessage[]

  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@map("users")
}

// ─── Country ──────────────────────────────────────────────────────────────────

model Country {
  id         String   @id @default(cuid())
  name       String   @unique
  code       String   @unique
  flag_url   String?

  leagues    League[]
  teams      Team[]
  players    Player[]

  @@map("countries")
}

// ─── League / Competition ─────────────────────────────────────────────────────

model League {
  id               String   @id @default(cuid())
  api_football_id  Int?     @unique
  name             String
  short_name       String?
  logo_url         String?
  country_id       String?
  country          Country? @relation(fields: [country_id], references: [id])
  sub_type         String?
  is_active        Boolean  @default(true)

  seasons     Season[]
  favorites   User[]   @relation("UserFavoriteLeagues")

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("leagues")
}

// ─── Season ───────────────────────────────────────────────────────────────────

model Season {
  id              String   @id @default(cuid())
  sportmonks_id   Int?     @unique
  league_id       String
  league          League   @relation(fields: [league_id], references: [id])
  year            Int
  start_date      DateTime
  end_date        DateTime
  is_current      Boolean  @default(false)

  matches     Match[]
  standings   Standing[]

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([league_id, year])
  @@map("seasons")
}

// ─── Team ─────────────────────────────────────────────────────────────────────

model Team {
  id               String   @id @default(cuid())
  api_football_id  Int?     @unique
  name             String
  short_name       String?
  code             String?
  logo_url         String?
  country_id       String?
  country          Country? @relation(fields: [country_id], references: [id])
  founded          Int?
  stadium          String?
  venue_city       String?
  is_active        Boolean  @default(true)

  home_matches    Match[]          @relation("HomeTeam")
  away_matches    Match[]          @relation("AwayTeam")
  players         Player[]
  standings       Standing[]
  statistics      MatchStatistic[]
  lineups         MatchLineup[]
  favorites       User[]           @relation("UserFavoriteTeams")
  form_entries    TeamForm[]
  form_as_opponent TeamForm[]      @relation("TeamFormOpponent")

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("teams")
}

// ─── Player ───────────────────────────────────────────────────────────────────

model Player {
  id               String         @id @default(cuid())
  api_football_id  Int?           @unique
  name             String
  first_name       String?
  last_name        String?
  photo_url        String?
  nationality      String?
  country_id       String?
  country          Country?       @relation(fields: [country_id], references: [id])
  date_of_birth    DateTime?
  position         PlayerPosition?
  number           Int?
  team_id          String?
  team             Team?          @relation(fields: [team_id], references: [id])
  is_active        Boolean        @default(true)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("players")
}

// ─── Team Form ────────────────────────────────────────────────────────────────
// Last N finished matches per team, synced independently from the main fixtures.
// Stored flat so it never pollutes the matches table with historical context data.

model TeamForm {
  id           String   @id @default(cuid())
  team_id      String
  team         Team     @relation(fields: [team_id], references: [id])
  opponent_id  String
  opponent     Team     @relation("TeamFormOpponent", fields: [opponent_id], references: [id])
  is_home      Boolean
  home_score   Int
  away_score   Int
  kickoff_at   DateTime
  league_name  String?
  league_logo  String?

  @@index([team_id, kickoff_at])
  @@map("team_form")
}

// ─── Match / Fixture ──────────────────────────────────────────────────────────

model Match {
  id               String      @id @default(cuid())
  api_football_id  Int?        @unique
  season_id        String
  season         Season      @relation(fields: [season_id], references: [id])
  home_team_id   String
  home_team      Team        @relation("HomeTeam", fields: [home_team_id], references: [id])
  away_team_id   String
  away_team      Team        @relation("AwayTeam", fields: [away_team_id], references: [id])
  kickoff_at     DateTime
  status         MatchStatus @default(SCHEDULED)
  minute              Int?
  extra_minute        Int?
  period_started_at   Int?
  period_counts_from  Int?
  period_length       Int?
  home_score     Int?
  away_score     Int?
  home_ht_score  Int?
  away_ht_score  Int?
  venue          String?      // name fallback
  venue_id       String?
  venue_ref      Venue?       @relation(fields: [venue_id], references: [id])
  referee        String?
  home_formation String?
  away_formation String?

  events         MatchEvent[]
  statistics     MatchStatistic[]
  lineups        MatchLineup[]
  commentary     MatchCommentary[]
  texts          MatchText[]
  chat_messages  LiveChatMessage[]

  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("matches")
}

// ─── Venue ────────────────────────────────────────────────────────────────────

model Venue {
  id            String   @id @default(cuid())
  sportmonks_id Int?     @unique
  name          String
  city          String?
  country       String?
  address       String?
  capacity      Int?
  surface       String?
  image_url     String?
  latitude      Float?
  longitude     Float?

  matches       Match[]

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("venues")
}

// ─── Match Event ──────────────────────────────────────────────────────────────

model MatchEvent {
  id                  String   @id @default(cuid())
  sportmonks_id       BigInt?  @unique
  match_id            String
  match               Match    @relation(fields: [match_id], references: [id])
  type                String
  minute              Int
  extra_minute        Int?
  team_id             String?
  player_name         String?
  related_player_name String?
  detail              String?
  sort_order          Int?

  created_at  DateTime @default(now())

  @@map("match_events")
}

// ─── Match Commentary ─────────────────────────────────────────────────────────
// Play-by-play text feed (SportMonks /commentaries). Append-only — a line never
// changes once published, so we dedupe on sportmonks_id and only insert new ones.

model MatchCommentary {
  id            String   @id @default(cuid())
  sportmonks_id BigInt   @unique
  match_id      String
  match         Match    @relation(fields: [match_id], references: [id])
  minute        Int?
  extra_minute  Int?
  comment       String
  is_goal       Boolean  @default(false)
  is_important  Boolean  @default(false)
  order         Int
  player_name   String?

  created_at    DateTime @default(now())

  @@index([match_id, order])
  @@map("match_commentaries")
}

// ─── Match Lineup ──────────────────────────────────────────────────────────────

model MatchLineup {
  id                   String  @id @default(cuid())
  sportmonks_id        BigInt? @unique
  match_id             String
  match                Match   @relation(fields: [match_id], references: [id])
  team_id              String
  team                 Team    @relation(fields: [team_id], references: [id])
  player_name          String
  player_photo         String?
  jersey_number        Int?
  position             String?
  formation_field      String?
  is_starting          Boolean @default(true)
  sportmonks_player_id Int?

  @@map("match_lineups")
}

// ─── Match Text (LLM-authored, generate-once-lock-in) ────────────────────────
// One row per (match, kind) — written exactly once, the moment that phase-text's
// content is final, then served from here forever. See docs/match-page-spec.md §5.

model MatchText {
  id           String        @id @default(cuid())
  match_id     String
  match        Match         @relation(fields: [match_id], references: [id])
  kind         MatchTextKind
  body         String
  generated_at DateTime      @default(now())

  @@unique([match_id, kind])
  @@map("match_texts")
}

// ─── Cache ────────────────────────────────────────────────────────────────────
// Generic key/value cache for slow-changing passthrough data (e.g. brackets,
// match previews). Avoids hammering external APIs; shared across instances.

model Cache {
  key        String   @id
  payload    Json
  expires_at DateTime

  updated_at DateTime @updatedAt

  @@index([expires_at])
  @@map("cache")
}

// ─── Standing ─────────────────────────────────────────────────────────────────

model Standing {
  id             String  @id @default(cuid())
  season_id      String
  season         Season  @relation(fields: [season_id], references: [id])
  team_id        String
  team           Team    @relation(fields: [team_id], references: [id])
  position       Int
  played         Int     @default(0)
  won            Int     @default(0)
  drawn          Int     @default(0)
  lost           Int     @default(0)
  goals_for      Int     @default(0)
  goals_against  Int     @default(0)
  goal_diff      Int     @default(0)
  points         Int     @default(0)
  form           String?
  group          String?

  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@unique([season_id, team_id])
  @@map("standings")
}

// ─── Match Statistic ──────────────────────────────────────────────────────────

model MatchStatistic {
  id              String  @id @default(cuid())
  match_id        String
  match           Match   @relation(fields: [match_id], references: [id])
  team_id         String
  team            Team    @relation(fields: [team_id], references: [id])
  possession      Float?
  shots           Int?
  shots_on_target Int?
  xg              Float?
  corners         Int?
  fouls           Int?
  yellow_cards    Int?
  red_cards       Int?

  updated_at      DateTime @updatedAt

  @@unique([match_id, team_id])
  @@map("match_statistics")
}

// ─── Article / News ───────────────────────────────────────────────────────────

model Article {
  id           String          @id @default(cuid())
  title        String
  slug         String          @unique
  excerpt      String?
  content      String
  cover_url    String?
  category     ArticleCategory @default(NEWS)
  is_published Boolean         @default(false)
  published_at DateTime?
  author_id    String
  author       User            @relation(fields: [author_id], references: [id])
  tags         String[]
  source_url   String?  @unique

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("articles")
}

// ─── Live Chat ────────────────────────────────────────────────────────────────

enum ChatAttachmentType {
  IMAGE
  AUDIO
}

model LiveChatMessage {
  id                  String   @id @default(cuid())
  match_id            String
  match               Match    @relation(fields: [match_id], references: [id], onDelete: Cascade)
  user_id             String
  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  content             String
  attachment_url      String?
  attachment_type     ChatAttachmentType?
  attachment_duration Int?     // seconds — voice notes only
  reply_to_id         String?
  reply_to            LiveChatMessage?  @relation("MessageReplies", fields: [reply_to_id], references: [id], onDelete: SetNull)
  replies             LiveChatMessage[] @relation("MessageReplies")
  created_at          DateTime @default(now())

  @@index([match_id, created_at])
  @@map("live_chat_messages")
}
